# Environment Variables (CRITICAL SECURITY)
.env
.env.local
.env.*

# ...but keep the safe templates
!.env.example
!**/.env.example

# Python Backend
backend/venv/
backend/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Node / React Frontend
frontend/node_modules/
frontend/dist/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# TLS certificates (never commit private keys)
deploy/certs/*
!deploy/certs/.gitkeep

# OS / Editor Files
.DS_Store
.vscode/