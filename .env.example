# ── Talamanda Trust Node — PRODUCTION compose env ─────────────────────────────
# Copy to `.env` next to docker-compose.prod.yml and fill in real values.
# Generate secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# NEVER commit a populated .env.

# Postgres
POSTGRES_PASSWORD=

# Auth / crypto (all REQUIRED in production)
JWT_SECRET=
ENCRYPTION_KEY=
# RSA private key (PEM). Generate:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
NOTARY_PRIVATE_KEY_PEM=

# Explicit CORS allow-list (comma-separated), e.g. https://app.yourco.com
CORS_ORIGINS=

# Optional global/agent API keys (comma-separated). Per-user ingress keys are
# issued automatically on signup.
API_KEYS=

# Provider keys are normally configured per-tenant in the dashboard, but you can
# seed the default tenant here.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Tuning
RISK_HOLD_THRESHOLD=0.6
RATE_LIMIT_PER_MINUTE=120
AUDIT_RETENTION_DAYS=365
ENCRYPT_AUDIT_CONTENT=true
UVICORN_WORKERS=2

# Observability (optional)
OTEL_EXPORTER=none
OTEL_EXPORTER_ENDPOINT=

# Public hostname (for your records / cert issuance)
PUBLIC_HOST=trust.yourco.com
