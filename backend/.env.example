# ── Talamanda Trust Layer — environment template ──────────────────────────────
# Copy to `.env` and fill in real values. NEVER commit a populated .env.

# Core
ENVIRONMENT=development
# Set to /api when the gateway is served behind nginx at /api (Docker). Leave empty for local :8000.
ROOT_PATH=

# Database (Postgres / Supabase)
DATABASE_URL=postgresql://user:password@host:5432/postgres
DB_SSL_REQUIRED=true

# LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Platform-owner Anthropic key that funds the AI summarizer + Saturn support bot
# for ALL users (separate from per-tenant provider keys set in the Gateway UI).
# Falls back to ANTHROPIC_API_KEY if unset.
OWNER_ANTHROPIC_API_KEY=

# Model pricing/catalog auto-sync (LiteLLM maintained dataset, deterministic).
# Keeps prices + the model catalog current without code changes. Runs on boot
# and every PRICING_SYNC_INTERVAL_HOURS. Set PRICING_SYNC_ENABLED=false to pin.
PRICING_SYNC_ENABLED=true
PRICING_SYNC_INTERVAL_HOURS=24
# PRICING_SYNC_URL=https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json

# Ingress auth
# Comma-separated API keys accepted by the gateway. Leave empty to DISABLE auth
# (development only — never in production).
API_KEYS=
# REQUIRED in production. Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=7
# Short-lived access token + rotating refresh token (XSS-hardening).
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=30
# REQUIRED in production: explicit comma-separated allow-list, e.g.
# https://app.yourco.com,https://admin.yourco.com  (never '*' in prod)
CORS_ORIGINS=*

# Public dashboard URL — used to build email verification / password-reset links.
APP_BASE_URL=http://localhost:5173
# Require users to verify their email before they can sign in.
REQUIRE_EMAIL_VERIFICATION=false

# Email (account verification + password reset). Leave SMTP_HOST empty in dev to
# print links to the server log instead of sending real mail.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@talamanda.local
SMTP_TLS=true

# Encrypts provider API keys (and optionally audit content) at rest. Set a
# strong, STABLE passphrase in any non-dev environment (if it changes, stored
# secrets can't be decrypted). Falls back to JWT_SECRET; plaintext if both empty.
# REQUIRED in production.
ENCRYPTION_KEY=

# Password / login safety
PASSWORD_MIN_LENGTH=10
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Rate limiting (Redis backend recommended in production for multi-worker safety)
RATE_LIMIT_PER_MINUTE=120
REDIS_URL=

# Request / LLM guards
MAX_REQUEST_BYTES=1000000
MAX_PROMPT_CHARS=100000
MAX_OUTPUT_TOKENS=4096
LLM_TIMEOUT_SECONDS=60

# Audit data governance
# 0 = keep audit logs forever; otherwise purge older than N days (hourly job).
AUDIT_RETENTION_DAYS=0
# Encrypt prompt/response columns at rest (uses ENCRYPTION_KEY).
ENCRYPT_AUDIT_CONTENT=false

# Observability / transport security
# none (default) | console (dev) | otlp (ship to a collector)
OTEL_EXPORTER=none
OTEL_EXPORTER_ENDPOINT=
SECURITY_HEADERS=true
# Enable HSTS only when served over HTTPS (behind the TLS proxy).
HSTS=false

# Schema management: true in dev (auto create/sync), MUST be false in production
# (use Alembic: `alembic upgrade head`).
AUTO_MIGRATE=true

# Risk gate: actions scoring at/above this composite risk are held for review.
RISK_HOLD_THRESHOLD=0.6

# ── Cost accounting & budgets ─────────────────────────────────────────────────
# Price multiplier for cached input tokens when a model has no explicit cached
# rate (most providers discount cache reads heavily, ~0.1–0.5x).
CACHED_INPUT_RATIO=0.5
# Default spend caps in USD (0 = unlimited). Per-tenant overrides set via API.
DEFAULT_DAILY_BUDGET_USD=0
DEFAULT_MONTHLY_BUDGET_USD=0
# Alert once spend crosses this fraction of a budget (0.8 = 80%).
BUDGET_ALERT_FRACTION=0.8

# Vector DB for the Librarian control library (memory | pgvector | pinecone).
# pgvector persists embeddings in Postgres (requires the `vector` extension).
VECTOR_BACKEND=memory
PINECONE_API_KEY=
PINECONE_INDEX=talamanda-controls

# Embeddings backend: auto (OpenAI if a key exists, else local) | openai | local
EMBEDDING_BACKEND=auto
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=256

# Security scanning (defence in depth on top of the regex pre-screen)
# LLM-based injection/jailbreak classifier (costs tokens + latency).
SECURITY_LLM_SCAN=false
SECURITY_SCAN_MODEL=
# Scan model responses for leaked secrets/PII/unsafe content.
SECURITY_SCAN_OUTPUTS=true

# Notary signing — PEM RSA private key (multiline; use \n or quote in shells).
# Leave empty in dev to auto-generate an ephemeral key at startup.
NOTARY_PRIVATE_KEY_PEM=
# Signer backend: local (PEM above) | kms (cloud KMS/HSM — see signing.py).
NOTARY_KEY_BACKEND=local
# Retired PUBLIC keys (concatenated PEM blocks) so evidence signed before a key
# rotation still verifies.
NOTARY_VERIFY_KEYS=

# Regulation feed ingester
REGULATION_FEED_INTERVAL_HOURS=6

# Alerting
ALERT_WEBHOOK_URL=
