# ── Talamanda Trust Layer — environment template ──────────────────────────────
# Copy to `.env` and fill in real values. NEVER commit a populated .env.

# Core
ENVIRONMENT=development
# Set to /api when the gateway is served behind nginx at /api (Docker). Leave empty for local :8000.
ROOT_PATH=

# Database (Postgres / Supabase)
DATABASE_URL=postgresql://user:password@host:5432/postgres
DB_SSL_REQUIRED=true

# LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Ingress auth
# Comma-separated API keys accepted by the gateway. Leave empty to DISABLE auth
# (development only — never in production).
API_KEYS=
JWT_SECRET=
JWT_ALGORITHM=HS256
CORS_ORIGINS=*

# Rate limiting
RATE_LIMIT_PER_MINUTE=120

# Risk gate: actions scoring at/above this composite risk are held for review.
RISK_HOLD_THRESHOLD=0.6

# Vector DB for the Librarian control library (memory | pgvector | pinecone)
VECTOR_BACKEND=memory
PINECONE_API_KEY=
PINECONE_INDEX=talamanda-controls

# Notary signing — PEM RSA private key (multiline; use \n or quote in shells).
# Leave empty in dev to auto-generate an ephemeral key at startup.
NOTARY_PRIVATE_KEY_PEM=

# Regulation feed ingester
REGULATION_FEED_INTERVAL_HOURS=6

# Alerting
ALERT_WEBHOOK_URL=
